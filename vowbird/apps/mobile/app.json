{
  "expo": {
    "name": "Vowbird",
    "slug": "vowbird",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "vowbird",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f1729"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.vowbird.mobile",
      "associatedDomains": ["applinks:vowbird.app", "applinks:www.vowbird.app"]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f1729"
      },
      "package": "app.vowbird.mobile",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "category": ["BROWSABLE", "DEFAULT"],
          "data": [
            {
              "scheme": "https",
              "host": "vowbird.app",
              "pathPrefix": "/p"
            },
            {
              "scheme": "https",
              "host": "vowbird.app",
              "pathPrefix": "/u"
            },
            {
              "scheme": "https",
              "host": "www.vowbird.app",
              "pathPrefix": "/p"
            },
            {
              "scheme": "https",
              "host": "www.vowbird.app",
              "pathPrefix": "/u"
            }
          ]
        }
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#d4a853"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Vowbird to attach proof photos to check-ins."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      },
      "apiUrl": "http://localhost:4000"
    }
  }
}
