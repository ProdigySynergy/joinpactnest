generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum ProfileMode {
  VEILED
  OPEN
}

enum Gender {
  MALE
  FEMALE
  FLUID
}

enum Plan {
  FREE
  PLUS
}

enum VowCategory {
  FITNESS
  STUDY
  CAREER
  FAITH
  MONEY
  WELLNESS
  CREATIVE
  BUSINESS
  READING
  CUSTOM
}

enum FrequencyType {
  DAILY
  WEEKLY
}

enum VowStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum VowVisibility {
  PRIVATE
  PARTNER
  GROUP_PUBLIC
}

enum PactPrivacy {
  PUBLIC
  INVITE_ONLY
  PRIVATE
}

enum ProfileModeAllowed {
  VEILED_ONLY
  OPEN_ONLY
  BOTH
}

enum PactStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum PactMemberRole {
  OWNER
  MODERATOR
  MEMBER
}

enum PartnerRequestStatus {
  WAITING
  PENDING
  MATCHED
  CANCELLED
  DECLINED
}

enum ProfileModePreference {
  VEILED
  OPEN
  EITHER
}

enum PartnerMatchStatus {
  ACTIVE
  ENDED
  BLOCKED
}

enum CheckInStatus {
  COMPLETED
  MISSED
}

enum MoodType {
  STRUGGLING
  OUT_OF_IT
  OKAY
  FOCUSED
  MOTIVATED
  PROUD
}

enum EncouragementSticker {
  KEEP_GOING
  PROUD_OF_YOU
  YOUVE_GOT_THIS
  ONE_STEP
  BREATHING_WITH_YOU
  ROOTING_FOR_YOU
}

enum LetterType {
  PARTNER_LETTER
  FUTURE_SELF
  GROUP_REFLECTION
}

enum LetterStatus {
  DRAFT
  SENT
  SCHEDULED
  UNLOCKED
}

enum ReactionType {
  FIRE
  CLAP
  HEART
  LOCKED_IN
  PROUD
  KEEP_GOING
}

enum ReportStatus {
  OPEN
  REVIEWED
  ACTION_TAKEN
  DISMISSED
}

enum PushPlatform {
  IOS
  ANDROID
  WEB
}

enum PacterRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

model User {
  id                   String       @id @default(cuid())
  name                 String
  username             String       @unique
  email                String       @unique
  passwordHash         String
  role                 UserRole     @default(USER)
  profileMode          ProfileMode  @default(VEILED)
  anonymousAlias       String?
  avatarUrl            String?
  bio                  String?      @db.Text
  tagline              String?
  gender               Gender?
  timezone             String       @default("America/New_York")
  preferredCheckInTime String       @default("09:00")
  plan                 Plan         @default(FREE)
  subscriptionStatus   String?
  subscriptionProvider String?
  subscriptionId       String?
  isSuspended          Boolean      @default(false)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  vows                 Vow[]
  ownedPacts           Pact[]              @relation("PactOwner")
  pactMembers          PactMember[]
  partnerRequests      PartnerRequest[]    @relation("PartnerRequestFrom")
  incomingPartnerRequests PartnerRequest[] @relation("PartnerRequestTarget")
  matchesAsA           PartnerMatch[]      @relation("MatchUserA")
  matchesAsB           PartnerMatch[]      @relation("MatchUserB")
  checkIns             CheckIn[]
  sentLetters          Letter[]            @relation("LetterSender")
  receivedLetters      Letter[]            @relation("LetterRecipient")
  roomPosts            RoomPost[]
  reactions            Reaction[]
  moodUpdates          MoodUpdate[]
  encouragementsSent   Encouragement[]     @relation("EncouragementFrom")
  encouragementsReceived Encouragement[]   @relation("EncouragementTo")
  reportsMade          Report[]            @relation("ReportReporter")
  reportsAgainst       Report[]            @relation("ReportReportedUser")
  reportComments       ReportComment[]
  blocksMade           Block[]             @relation("BlockBlocker")
  blocksReceived       Block[]             @relation("BlockBlocked")
  pacterRequestsSent   PacterRequest[]     @relation("PacterFrom")
  pacterRequestsReceived PacterRequest[]   @relation("PacterTo")
  pacterMutesMade      PacterMute[]        @relation("PacterMuteBy")
  pacterMutesReceived  PacterMute[]        @relation("PacterMuted")
  e2eKey               E2eKey?
  dmSent               DirectMessage[]     @relation("DmSender")
  dmReceived           DirectMessage[]     @relation("DmRecipient")
  notificationPref     NotificationPreference?
  pushTokens           PushToken[]
  uploadedFiles        UploadedFile[]
  passwordResetTokens  PasswordResetToken[]

  @@index([isSuspended])
  @@index([profileMode])
}

model Vow {
  id                 String         @id @default(cuid())
  userId             String
  title              String
  reason             String?        @db.Text
  category           VowCategory
  frequencyType      FrequencyType
  targetCountPerWeek Int            @default(1)
  startDate          DateTime       @db.Date
  endDate            DateTime?      @db.Date
  status             VowStatus      @default(ACTIVE)
  visibility         VowVisibility  @default(PRIVATE)
  noJudgementZone    Boolean        @default(false)
  leaderboardEnabled Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  partnerRequests    PartnerRequest[]
  partnerMatches     PartnerMatch[]
  checkIns           CheckIn[]
  letters            Letter[]
  moodUpdates        MoodUpdate[]

  @@index([userId])
  @@index([status])
  @@index([category])
}

model Pact {
  id                   String             @id @default(cuid())
  ownerId              String
  title                String
  slug                 String             @unique
  description          String?            @db.Text
  category             VowCategory
  privacy              PactPrivacy        @default(PUBLIC)
  profileModeAllowed   ProfileModeAllowed @default(BOTH)
  frequencyType        FrequencyType      @default(DAILY)
  targetCountPerWeek   Int                @default(7)
  checkInStartTime     String             @default("06:00")
  checkInEndTime       String             @default("23:59")
  startDate            DateTime           @db.Date
  endDate              DateTime?          @db.Date
  inviteCode           String             @unique
  status               PactStatus         @default(ACTIVE)
  noJudgementZone      Boolean            @default(false)
  leaderboardEnabled   Boolean            @default(true)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  owner                User               @relation("PactOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members              PactMember[]
  checkIns             CheckIn[]
  letters              Letter[]
  roomPosts            RoomPost[]
  moodUpdates          MoodUpdate[]

  @@index([ownerId])
  @@index([privacy])
  @@index([status])
}

model PactMember {
  id                  String         @id @default(cuid())
  pactId              String
  userId              String
  role                PactMemberRole @default(MEMBER)
  displayModeInPact   ProfileMode    @default(VEILED)
  joinedAt            DateTime       @default(now())
  leftAt              DateTime?

  pact                Pact           @relation(fields: [pactId], references: [id], onDelete: Cascade)
  user                User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pactId, userId])
  @@index([userId])
}

model PartnerRequest {
  id                    String                @id @default(cuid())
  userId                String
  vowId                 String
  /// When set, this is a directed invite (status PENDING) rather than auto-queue (WAITING).
  targetUserId          String?
  category              VowCategory
  frequencyType         FrequencyType
  timezone              String
  preferredCheckInTime  String
  profileModePreference ProfileModePreference @default(EITHER)
  tonePreference        String
  status                PartnerRequestStatus  @default(WAITING)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  user                  User                  @relation("PartnerRequestFrom", fields: [userId], references: [id], onDelete: Cascade)
  targetUser            User?                 @relation("PartnerRequestTarget", fields: [targetUserId], references: [id], onDelete: Cascade)
  vow                   Vow                   @relation(fields: [vowId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([targetUserId])
  @@index([status])
  @@index([category])
}

model PartnerMatch {
  id        String             @id @default(cuid())
  vowId     String
  userAId   String
  userBId   String
  status    PartnerMatchStatus @default(ACTIVE)
  matchMode ProfileMode        @default(VEILED)
  createdAt DateTime           @default(now())
  endedAt   DateTime?

  vow       Vow                @relation(fields: [vowId], references: [id], onDelete: Cascade)
  userA     User               @relation("MatchUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB     User               @relation("MatchUserB", fields: [userBId], references: [id], onDelete: Cascade)
  letters   Letter[]
  moodUpdates MoodUpdate[]

  @@index([userAId])
  @@index([userBId])
  @@index([vowId])
  @@index([status])
}

model MoodUpdate {
  id             String        @id @default(cuid())
  userId         String
  vowId          String?
  pactId         String?
  partnerMatchId String?
  mood           MoodType
  note           String?       @db.VarChar(280)
  createdAt      DateTime      @default(now())

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  vow            Vow?          @relation(fields: [vowId], references: [id], onDelete: Cascade)
  pact           Pact?         @relation(fields: [pactId], references: [id], onDelete: Cascade)
  partnerMatch   PartnerMatch? @relation(fields: [partnerMatchId], references: [id], onDelete: Cascade)
  encouragements Encouragement[]

  @@index([userId])
  @@index([vowId])
  @@index([pactId])
  @@index([partnerMatchId])
  @@index([createdAt])
}

model Encouragement {
  id           String                @id @default(cuid())
  fromUserId   String
  toUserId     String
  moodUpdateId String
  sticker      EncouragementSticker
  note         String?               @db.VarChar(140)
  createdAt    DateTime              @default(now())

  fromUser     User                  @relation("EncouragementFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser       User                  @relation("EncouragementTo", fields: [toUserId], references: [id], onDelete: Cascade)
  moodUpdate   MoodUpdate            @relation(fields: [moodUpdateId], references: [id], onDelete: Cascade)

  @@index([moodUpdateId])
  @@index([fromUserId])
  @@index([toUserId])
}

model CheckIn {
  id            String        @id @default(cuid())
  userId        String
  vowId         String?
  pactId        String?
  note          String?       @db.Text
  proofImageUrl String?
  checkInDate   DateTime      @db.Date
  status        CheckInStatus @default(COMPLETED)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  vow           Vow?          @relation(fields: [vowId], references: [id], onDelete: Cascade)
  pact          Pact?         @relation(fields: [pactId], references: [id], onDelete: Cascade)
  reactions     Reaction[]
  reports       Report[]

  @@unique([userId, vowId, checkInDate])
  @@unique([userId, pactId, checkInDate])
  @@index([userId])
  @@index([checkInDate])
}

model Letter {
  id              String       @id @default(cuid())
  senderId        String
  recipientId     String?
  vowId           String?
  pactId          String?
  partnerMatchId  String?
  type            LetterType
  subject         String
  body            String       @db.Text
  status          LetterStatus @default(DRAFT)
  unlockAt        DateTime?
  sentAt          DateTime?
  readAt          DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  sender          User         @relation("LetterSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient       User?        @relation("LetterRecipient", fields: [recipientId], references: [id], onDelete: SetNull)
  vow             Vow?         @relation(fields: [vowId], references: [id], onDelete: SetNull)
  pact            Pact?        @relation(fields: [pactId], references: [id], onDelete: SetNull)
  partnerMatch    PartnerMatch? @relation(fields: [partnerMatchId], references: [id], onDelete: SetNull)
  reactions       Reaction[]
  reports         Report[]

  @@index([senderId])
  @@index([recipientId])
  @@index([status])
}

model RoomPost {
  id        String    @id @default(cuid())
  pactId    String
  userId    String
  body      String    @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  hiddenAt  DateTime?

  pact      Pact      @relation(fields: [pactId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions Reaction[]
  reports   Report[]

  @@index([pactId])
  @@index([userId])
}

model Reaction {
  id        String       @id @default(cuid())
  userId    String
  checkInId String?
  letterId  String?
  postId    String?
  type      ReactionType
  createdAt DateTime     @default(now())

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  checkIn   CheckIn?     @relation(fields: [checkInId], references: [id], onDelete: Cascade)
  letter    Letter?      @relation(fields: [letterId], references: [id], onDelete: Cascade)
  post      RoomPost?    @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([checkInId])
  @@index([letterId])
  @@index([postId])
}

model Report {
  id              String       @id @default(cuid())
  reporterId      String
  reportedUserId  String?
  postId          String?
  checkInId       String?
  letterId        String?
  reason          String
  details         String?      @db.Text
  status          ReportStatus @default(OPEN)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  reporter        User         @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reportedUser    User?        @relation("ReportReportedUser", fields: [reportedUserId], references: [id], onDelete: SetNull)
  post            RoomPost?    @relation(fields: [postId], references: [id], onDelete: SetNull)
  checkIn         CheckIn?     @relation(fields: [checkInId], references: [id], onDelete: SetNull)
  letter          Letter?      @relation(fields: [letterId], references: [id], onDelete: SetNull)
  comments        ReportComment[]

  @@index([status])
  @@index([reportedUserId])
  @@index([reporterId])
  @@index([reporterId, reportedUserId, status])
}

model ReportComment {
  id        String   @id @default(cuid())
  reportId  String
  authorId  String
  body      String   @db.Text
  createdAt DateTime @default(now())

  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([authorId])
}

model Block {
  id            String   @id @default(cuid())
  blockerId     String
  blockedUserId String
  reason        String?
  createdAt     DateTime @default(now())

  blocker       User     @relation("BlockBlocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedUser   User     @relation("BlockBlocked", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedUserId])
  @@index([blockerId])
  @@index([blockedUserId])
}

model PacterRequest {
  id         String              @id @default(cuid())
  fromUserId String
  toUserId   String
  status     PacterRequestStatus @default(PENDING)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  fromUser   User                @relation("PacterFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser     User                @relation("PacterTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@index([toUserId, status])
  @@index([fromUserId, status])
}

/// Soft hide from Pactered list — does not leave shared pacts.
model PacterMute {
  id          String   @id @default(cuid())
  userId      String
  mutedUserId String
  createdAt   DateTime @default(now())

  user        User     @relation("PacterMuteBy", fields: [userId], references: [id], onDelete: Cascade)
  mutedUser   User     @relation("PacterMuted", fields: [mutedUserId], references: [id], onDelete: Cascade)

  @@unique([userId, mutedUserId])
  @@index([userId])
}

/// Public half of a user's E2E identity key (private key never leaves the client).
model E2eKey {
  userId    String   @id
  publicKey String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Direct messages — E2E ciphertext when both parties have keys; plaintext fallback otherwise.
model DirectMessage {
  id          String   @id @default(cuid())
  senderId    String
  recipientId String
  ciphertext  String   @db.Text
  iv          String
  /// false = body stored as plaintext in ciphertext (server-readable fallback)
  encrypted   Boolean  @default(true)
  createdAt   DateTime @default(now())

  sender      User     @relation("DmSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient   User     @relation("DmRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([senderId, recipientId, createdAt])
  @@index([recipientId, senderId, createdAt])
  @@index([createdAt])
}

model NotificationPreference {
  id                String   @id @default(cuid())
  userId            String   @unique
  checkInReminder   Boolean  @default(true)
  partnerCheckedIn  Boolean  @default(true)
  partnerLetter     Boolean  @default(true)
  missedCheckIn     Boolean  @default(true)
  pactEndingSoon    Boolean  @default(true)
  weeklyReflection  Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PushToken {
  id        String       @id @default(cuid())
  userId    String
  token     String
  platform  PushPlatform
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
  @@index([userId])
}

model UploadedFile {
  id        String   @id @default(cuid())
  userId    String
  filename  String
  path      String
  mimeType  String
  size      Int
  purpose   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
